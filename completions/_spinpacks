#compdef spinpacks

_spinpacks_packs() {
  local packs
  packs=(${(f)"$(spinpacks list 2>/dev/null)"})
  _describe 'pack' packs
}

_spinpacks() {
  local -a commands
  commands=(
    'list:List available packs'
    'ls:List available packs'
    'install:Install a pack into Claude Code settings'
    'add:Install a pack into Claude Code settings (alias for install)'
    'uninstall:Remove a pack from Claude Code settings'
    'remove:Remove a pack from Claude Code settings (alias for uninstall)'
    'update:Reinstall packs'
    'status:Show status'
    'mode:Get or set spinnerVerbs.mode'
    'sample:Sample random verbs from a pack'
    'info:Show pack details'
    'show:Show pack details (alias for info)'
    'search:Search packs by name or verb content'
    'doctor:Check for configuration problems'
    'version:Print version'
    'completion:Generate shell completion'
    'help:Show help'
  )

  _arguments -C \
    '(-V --version)'{-V,--version}'[Print version]' \
    '(-h --help)'{-h,--help}'[Show help]' \
    '1: :->command' \
    '*:: :->args'

  case $state in
    command) _describe 'command' commands ;;
    args)
      case $words[1] in
        install|add)
          _arguments \
            '--scope[Target scope]:scope:(user project local managed)' \
            '--force[Skip safety guards]' \
            '--dry-run[Show what would change without writing]' \
            '(-v --verbose)'{-v,--verbose}'[Show detailed output]' \
            '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
            '--json[Output as JSON]' \
            '1: :_spinpacks_packs'
          ;;
        sample)
          _arguments \
            '(-n --count)'{-n,--count}'[Number of verbs to sample]:count:' \
            '--json[Output as JSON]' \
            '1: :_spinpacks_packs'
          ;;
        info|show)
          _arguments \
            '(-v --verbose)'{-v,--verbose}'[List all verbs]' \
            '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
            '--json[Output as JSON]' \
            '1: :_spinpacks_packs'
          ;;
        uninstall|remove)
          _arguments \
            '--all[Operate on all tracked packs]' \
            '--force[Skip safety guards]' \
            '--dry-run[Show what would change without writing]' \
            '--scope[Target scope]:scope:(user project local managed)' \
            '(-v --verbose)'{-v,--verbose}'[Show detailed output]' \
            '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
            '--json[Output as JSON]' \
            '1: :_spinpacks_packs'
          ;;
        update)
          _arguments \
            '--all[Operate on all tracked packs]' \
            '--dry-run[Show what would change without writing]' \
            '--scope[Target scope]:scope:(user project local managed)' \
            '(-v --verbose)'{-v,--verbose}'[Show detailed output]' \
            '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
            '--json[Output as JSON]' \
            '1: :_spinpacks_packs'
          ;;
        list|ls)
          _arguments \
            '--installed[Show only installed packs]' \
            '--scope[Filter --installed to a specific scope]:scope:(user project local managed)' \
            '(-v --verbose)'{-v,--verbose}'[Show verb count per pack]' \
            '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
            '--json[Output as JSON]'
          ;;
        search)
          _arguments \
            '(-v --verbose)'{-v,--verbose}'[Show matching verbs]' \
            '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
            '--json[Output as JSON]' \
            '1: :'
          ;;
        status)
          _arguments \
            '--all[Show all scopes]' \
            '--scope[Target scope]:scope:(user project local managed)' \
            '(-v --verbose)'{-v,--verbose}'[List all active verbs]' \
            '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
            '--json[Output as JSON]'
          ;;
        mode)
          _arguments \
            '--dry-run[Show what would change without writing]' \
            '--scope[Target scope]:scope:(user project local managed)' \
            '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
            '--json[Output as JSON]' \
            '1: :(replace append)'
          ;;
        completion) _arguments '1: :(bash zsh fish)' ;;
      esac ;;
  esac
}

_spinpacks
