#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'
require 'optparse'
require 'fileutils'

VERSION           = '1.1.1'
PACKS_DIR         = File.expand_path('../packs', File.dirname(File.realpath(__FILE__)))
STATE_FILE        = File.expand_path('~/.local/state/spinpacks/state.json')
MAX_FILE_SIZE     = 1_048_576 # 1 MB
PACK_NAME_PATTERN = /\A[a-zA-Z0-9_\-]+\z/.freeze

CLAUDE_DIR = File.expand_path(ENV.fetch('CLAUDE_CONFIG_DIR', '~/.claude'))

SCOPES = {
  'user'    => File.join(CLAUDE_DIR, 'settings.json'),
  'project' => File.expand_path('.claude/settings.json'),
  'local'   => File.expand_path('.claude/settings.local.json'),
  'system'  => '/Library/Application Support/ClaudeCode/settings.json'
}.freeze

ALL_COMMANDS = %w[list ls apply install remove uninstall update status mode sample info search doctor version completions help].freeze

COMMAND_DESCRIPTIONS = {
  'list'        => 'List available packs',
  'ls'          => 'List available packs (alias for list)',
  'apply'       => 'Apply a pack to Claude Code settings',
  'install'     => 'Apply a pack to Claude Code settings (alias for apply)',
  'remove'      => 'Remove a pack from Claude Code settings',
  'uninstall'   => 'Remove a pack from Claude Code settings (alias for remove)',
  'update'      => 'Re-apply packs to pick up new verbs after an upgrade',
  'status'      => 'Show active verbs, mode, and tracked packs',
  'mode'        => "Get or set Claude Code's spinnerVerbs.mode",
  'sample'      => 'Print random verbs from a pack',
  'info'        => 'Show pack metadata and a sample of verbs',
  'search'      => 'Search packs by name, description, tags, or verb content',
  'doctor'      => 'Validate settings files, state file, and pack integrity',
  'version'     => 'Print the current version',
  'completions' => 'Generate shell completions for bash, zsh, or fish',
  'help'        => 'Show help, or detailed help for a specific command',
}.freeze

VALID_OPTIONS = {
  'list'        => %i[applied scope verbose quiet json no_color],
  'ls'          => %i[applied scope verbose quiet json no_color],
  'apply'       => %i[scope overwrite force dry_run verbose quiet json no_color],
  'install'     => %i[scope overwrite force dry_run verbose quiet json no_color],
  'remove'      => %i[scope force all dry_run verbose quiet json no_color],
  'uninstall'   => %i[scope force all dry_run verbose quiet json no_color],
  'update'      => %i[scope all dry_run verbose quiet json no_color],
  'status'      => %i[scope all verbose quiet json no_color],
  'mode'        => %i[scope dry_run quiet json no_color],
  'sample'      => %i[count json no_color],
  'info'        => %i[verbose quiet json no_color],
  'search'      => %i[verbose quiet json no_color],
  'doctor'      => %i[quiet json no_color],
  'completions' => [],
  'version'     => %i[json],
  'help'        => %i[json],
}.freeze

# --- Color ---------------------------------------------------------------

module Color
  CODES = {
    reset:  "\e[0m",
    bold:   "\e[1m",
    dim:    "\e[2m",
    red:    "\e[31m",
    green:  "\e[32m",
    yellow: "\e[33m",
    cyan:   "\e[36m"
  }.freeze

  @enabled = true

  def self.enabled=(val);              @enabled = val; end
  def self.enabled?(stream = $stdout); @enabled && stream.tty? && !ENV.key?('NO_COLOR'); end
  def self.c(code, str, stream = $stdout); enabled?(stream) ? "#{CODES[code]}#{str}#{CODES[:reset]}" : str; end
  def self.bold(str);    c(:bold,   str); end
  def self.dim(str);     c(:dim,    str); end
  def self.red(str);     c(:red,    str); end
  def self.green(str);   c(:green,  str); end
  def self.yellow(str);  c(:yellow, str); end
  def self.cyan(str);    c(:cyan,   str); end
  def self.red_err(str); c(:red,    str, $stderr); end
end

# --- Shell completions ---------------------------------------------------

ZSH_COMPLETION = <<~'ZSH'
  #compdef spinpacks

  _spinpacks_packs() {
    local packs
    packs=(${(f)"$(spinpacks list 2>/dev/null)"})
    _describe 'pack' packs
  }

  _spinpacks() {
    local -a commands
    commands=(
      'list:List available packs'
      'ls:List available packs'
      'apply:Apply a pack to Claude Code settings'
      'install:Apply a pack to Claude Code settings (alias for apply)'
      'remove:Remove a pack from Claude Code settings'
      'update:Re-apply packs'
      'status:Show status'
      'mode:Get or set spinnerVerbs.mode'
      'sample:Sample random verbs from a pack'
      'info:Show pack details'
      'search:Search packs by name or verb content'
      'doctor:Check for configuration problems'
      'version:Print version'
      'completions:Generate shell completions'
      'uninstall:Remove a pack (alias for remove)'
      'help:Show help'
    )

    _arguments -C \
      '(-V --version)'{-V,--version}'[Print version]' \
      '(-h --help)'{-h,--help}'[Show help]' \
      '1: :->command' \
      '*:: :->args'

    case $state in
      command) _describe 'command' commands ;;
      args)
        case $words[1] in
          apply|install|sample) _spinpacks_packs ;;
          info)
            _arguments \
              '(-v --verbose)'{-v,--verbose}'[List all verbs]' \
              '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
              '--json[Output as JSON]' \
              '1: :_spinpacks_packs'
            ;;
          remove|update)
            _arguments \
              '--all[Operate on all tracked packs]' \
              '--force[Skip safety guards]' \
              '--dry-run[Show what would change without writing]' \
              '--scope[Target scope]:scope:(user project local system)' \
              '(-v --verbose)'{-v,--verbose}'[Show detailed output]' \
              '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
              '--json[Output as JSON]' \
              '1: :_spinpacks_packs'
            ;;
          list|ls)
            _arguments \
              '--applied[Show only applied packs]' \
              '--scope[Filter --applied to a specific scope]:scope:(user project local system)' \
              '(-v --verbose)'{-v,--verbose}'[Show verb count per pack]' \
              '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
              '--json[Output as JSON]'
            ;;
          search)
            _arguments \
              '(-v --verbose)'{-v,--verbose}'[Show matching verbs]' \
              '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
              '--json[Output as JSON]' \
              '1: :'
            ;;
          uninstall)
            _arguments \
              '--all[Operate on all tracked packs]' \
              '--force[Skip safety guards]' \
              '--dry-run[Show what would change without writing]' \
              '--scope[Target scope]:scope:(user project local system)' \
              '(-v --verbose)'{-v,--verbose}'[Show detailed output]' \
              '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
              '--json[Output as JSON]' \
              '1: :_spinpacks_packs'
            ;;
          status)
            _arguments \
              '--all[Show all scopes]' \
              '--scope[Target scope]:scope:(user project local system)' \
              '(-v --verbose)'{-v,--verbose}'[List all active verbs]' \
              '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]' \
              '--json[Output as JSON]'
            ;;
          mode) _arguments '1: :(replace append)' ;;
          completions) _arguments '1: :(bash zsh fish)' ;;
        esac ;;
    esac
  }

  _spinpacks
ZSH

BASH_COMPLETION = <<~'BASH'
  _spinpacks() {
    local cur prev
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    local commands="list ls apply install remove uninstall update status mode sample info search doctor version completions help"

    case "$prev" in
      spinpacks) COMPREPLY=($(compgen -W "$commands" -- "$cur")); return ;;
      apply|install|remove|uninstall|sample|info|update)
        COMPREPLY=($(compgen -W "$(spinpacks list 2>/dev/null)" -- "$cur")); return ;;
      completions) COMPREPLY=($(compgen -W "bash zsh fish" -- "$cur")); return ;;
      mode)    COMPREPLY=($(compgen -W "replace append" -- "$cur")); return ;;
      --scope)     COMPREPLY=($(compgen -W "user project local system" -- "$cur")); return ;;
    esac

    if [[ "$cur" == -* ]]; then
      COMPREPLY=($(compgen -W "--scope --overwrite --force --all --applied --dry-run -v --verbose -q --quiet --json --no-color -V --version -h --help" -- "$cur"))
    fi
  }

  complete -F _spinpacks spinpacks
BASH

FISH_COMPLETION = <<~'FISH'
  function __spinpacks_packs
    spinpacks list 2>/dev/null
  end

  function __spinpacks_no_subcommand
    not __fish_seen_subcommand_from list ls apply install remove uninstall update status mode sample info search doctor version completions help
  end

  complete -c spinpacks -f -n __spinpacks_no_subcommand -a list        -d 'List available packs'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a ls          -d 'List available packs'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a apply       -d 'Apply a pack'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a install     -d 'Apply a pack (alias for apply)'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a remove      -d 'Remove a pack'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a update      -d 'Re-apply packs'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a status      -d 'Show status'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a mode        -d 'Get or set mode'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a sample      -d 'Sample random verbs from a pack'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a info        -d 'Show pack details'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a search      -d 'Search packs'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a doctor      -d 'Check for problems'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a version     -d 'Print version'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a completions -d 'Generate shell completions'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a uninstall   -d 'Remove a pack (alias for remove)'
  complete -c spinpacks -f -n __spinpacks_no_subcommand -a help        -d 'Show help'

  complete -c spinpacks -f -n '__fish_seen_subcommand_from apply remove uninstall sample info update' \
    -a '(__spinpacks_packs)'
  complete -c spinpacks -f -n '__fish_seen_subcommand_from mode'    -a 'replace append'
  complete -c spinpacks -f -n '__fish_seen_subcommand_from completions' -a 'bash zsh fish'

  complete -c spinpacks -l scope        -d 'Target scope' -r -a 'user project local system'
  complete -c spinpacks -l overwrite    -d 'Replace existing verbs instead of appending'
  complete -c spinpacks -l force        -d 'Skip safety guards'
  complete -c spinpacks -l all          -d 'Operate on all tracked packs or show all scopes'
  complete -c spinpacks -l applied      -d 'Show only applied packs (list/ls)'
  complete -c spinpacks -l dry-run      -d 'Show what would change without writing'
  complete -c spinpacks -s v -l verbose -d 'Show detailed output'
  complete -c spinpacks -s q -l quiet   -d 'Suppress non-error output'
  complete -c spinpacks -l json         -d 'Output as JSON'
  complete -c spinpacks -l no-color     -d 'Disable color output'
  complete -c spinpacks -s V -l version -d 'Print version'
  complete -c spinpacks -s h -l help    -d 'Show help'
FISH

COMPLETIONS = { 'zsh' => ZSH_COMPLETION, 'bash' => BASH_COMPLETION, 'fish' => FISH_COMPLETION }.freeze

